runner-config/
# ==========================================
# 1. OS & IDE 임시 파일 (Windows, WSL, VS Code)
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
Thumbs.db
Desktop.ini

# ==========================================
# 2. Terraform 관련 제외 설정 (infra_test)
# ==========================================
# 테라폼 초기화 시 다운로드되는 바이너리 폴더
**/infra_test/.terraform/

# 로컬에 저장되는 인프라 상태 파일 (보안 민감 데이터 포함)
*.tfstate
*.tfstate.*

# 테라폼 실행 중 생성되는 락(Lock) 파일
.terraform.tfstate.lock.info
*.tfstate.lock
*.hcl

# 테라폼 변수 입력 파일 (비밀키, 패스워드 등을 적는 파일이므로 절대 업로드 금지)
*.tfvars
*.tfvars.json

# 크래시 로그
crash.log
crash.*.log

# 테라폼 오버라이드 파일
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ==========================================
# 3. Ansible & eksctl 관련 제외 설정 (ansible_test)
# ==========================================
# 앤시블 실행 실패 시 생성되는 재시도 파일
*.retry

# 플레이북 실행 시 템플릿(.j2)에 의해 '동적'으로 생성되는 실제 EKS 설정 파일
# (이 파일은 로컬에서만 생성되어 쓰이고 지워져야 보안상 안전합니다)
**/ansible_test/eksctl-config.yaml

# ==========================================
# 4. 쿠버네티스 & 기타 임시 파일
# ==========================================
# 로컬에서 테스트용으로 간혹 추출하는 kubeconfig 파일 보호
kubeconfig
*.kubeconfig
.kube/

# 시스템 로그 파일
*.log

inventory.ini
pf_log.txt

*.tfvars
.env